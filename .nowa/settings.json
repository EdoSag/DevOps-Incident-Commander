{
    "version": "3.9.3",
    "app": {
        "name": "devops_incident_commander_dashboard",
        "bundleId": "com.example.devopsincidentcommanderdashboard"
    },
    "main": [
        {
            "key": "supabase",
            "statement": "await SupabaseService().initialize();",
            "imports": [
                "package:devops_incident_commander_dashboard/integrations/supabase_service.dart"
            ]
        }
    ],
    "experimental": {
        "load_packages": true
    },
    "permissions": [
        {
            "key": "NSCameraUsageDescription",
            "value": "Camera permission is required to take photos and videos."
        },
        {
            "key": "android.permission.CAMERA"
        }
    ]
}